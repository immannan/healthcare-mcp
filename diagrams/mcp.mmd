flowchart LR
  User["User<br/><small>Healthcare member</small>"]:::user

  subgraph Agent["AI Agent"]
    direction TB
    Orch["LLM (Model)<br/><small>Selects tools</small>"]:::srv
  end

  subgraph Client["MCP Client"]
    direction TB
    Transport["JSON-RPC<br/>transport"]:::srv
  end

  subgraph GW["MCP Gateway"]
    direction TB
    Auth["Authn / Authz"]:::gw
    Obs["Observability"]:::gw
    Scan["Tool scanning"]:::gw
    IP["IP restriction"]:::gw
  end

  subgraph Servers["MCP Servers"]
    direction TB
    S1["Eligibility<br/>MCP Server"]:::srv
    S2["Benefit Check<br/>MCP Server"]:::srv
    S3["Claims Inquiry<br/>MCP Server"]:::srv
    S4["Payments<br/>MCP Server"]:::srv
  end

  subgraph Tools["Tools & Resources"]
    direction TB
    T1["Eligibility DB / API"]:::tool
    T2["Benefit Plan API"]:::tool
    T3["Claims History DB"]:::tool
    T4["Payments Gateway"]:::tool
  end

  User -- "natural language" --> Orch
  Orch -- "StreamableHTTP POST" --> Transport
  Transport -- "StreamableHTTP POST" --> Auth
  Auth --> Obs --> Scan --> IP

  IP -- "POST /tools/call" --> S1
  IP -- "POST /tools/call" --> S2
  IP -- "POST /tools/call" --> S3
  IP -- "POST /tools/call" --> S4

  S1 -- "query" --> T1
  S2 -- "query" --> T2
  S3 -- "query" --> T3
  S4 -- "query" --> T4

  T1 -- "result" --> S1
  T2 -- "result" --> S2
  T3 -- "result" --> S3
  T4 -- "result" --> S4

  Transport -- "200 OK / response" --> Orch
  Orch -- "answer" --> User

  classDef user fill:#e6f1fb,color:#0c447c,stroke:#185fa5,stroke-width:1px
  classDef gw   fill:#f1efe8,color:#2c2c2a,stroke:#5f5e5a,stroke-width:1px
  classDef srv  fill:#0F2540,color:#ffffff,stroke:#1a4060,stroke-width:1px
  classDef tool fill:#e1f5ee,color:#085041,stroke:#0f6e56,stroke-width:1px