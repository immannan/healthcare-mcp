flowchart LR

  subgraph Coord ["Coordinator"]
    MA["Member Assist Agent<br/><small>Patient coordinator<br/>Eligibility · Provider search</small>"]:::srv
  end

  subgraph Protocol ["A2A Protocol"]
    direction TB
    ROUTER["Message Router<br/><small>JSON-RPC 2.0 · async/await</small>"]:::gw
    REG["Agent Registry<br/><small>Service discovery · Capabilities</small>"]:::gw
  end

  subgraph Agents ["Specialist Agents"]
    direction TB
    CA["Claims Agent<br/><small>check_member_eligibility<br/>get_claim_details</small>"]:::srv
    PA["Provider Advocate<br/><small>search_network_providers</small>"]:::srv
    BA["Benefits Agent<br/><small>calculate_member_responsibility</small>"]:::srv
  end

  subgraph Tools ["MCP Tools"]
    direction TB
    T1["list_member_claims<br/>get_member_benefits<br/>get_claim_detail"]:::tool
    T2["search_providers"]:::tool
    T3["estimate_member_responsibility"]:::tool
  end

  MA   -- "send_request"                    --> ROUTER
  ROUTER                                    --> REG
  ROUTER -- "check_member_eligibility"      --> CA
  ROUTER -- "search_network_providers"      --> PA
  CA     -- "calculate_member_responsibility"--> BA

  CA   -- "query" --> T1
  PA   -- "query" --> T2
  BA   -- "query" --> T3

  T1   -- "result" --> CA
  T2   -- "result" --> PA
  T3   -- "result" --> BA

  ROUTER -- "stream results"                --> MA

  classDef srv  fill:#0F2540,color:#ffffff,stroke:#1a4060,stroke-width:1px
  classDef gw   fill:#f1efe8,color:#2c2c2a,stroke:#5f5e5a,stroke-width:1px
  classDef tool fill:#e1f5ee,color:#085041,stroke:#0f6e56,stroke-width:1px
